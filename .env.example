# Copy this file to .env and fill in real values.
# DO NOT commit the real .env file.

# ----------- OpenAI STT -----------
# Required: your OpenAI API key
OPENAI_API_KEY= YOUR_OPENAI_API_KEY

# Optional: override API base URL (e.g. Azure/proxy)
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optional: default transcription model
# Common options: gpt-4o-mini-transcribe | gpt-4o-transcribe
OPENAI_STT_MODEL=gpt-4o-transcribe

# Optional: STT language hint (ISO-639-1, e.g. "en", "zh")
# Leave empty for auto-detect
OPENAI_STT_LANGUAGE=en

# Optional: priming prompt for transcription jargon/names
OPENAI_STT_PROMPT=

# Optional: timeout for OpenAI calls (seconds)
OPENAI_STT_TIMEOUT_SECONDS=120

# ----------- OpenAI LLM (intent/summarize) -----------
# Use models that your project can actually access
OPENAI_SUMMARY_MODEL=gpt-5.5
OPENAI_INTENT_MODEL=gpt-5.5
