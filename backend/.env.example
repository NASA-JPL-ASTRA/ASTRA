# Copy this file to backend/.env and fill in real values.
# DO NOT commit the real .env file.

# ─────────── OpenAI STT ───────────
# Required: your OpenAI API key
OPENAI_API_KEY=

# Optional: override the API base URL (e.g. for Azure/proxy)
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optional: default transcription model
# Supported: gpt-4o-mini-transcribe | gpt-4o-transcribe | gpt-4o-transcribe-diarize
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Optional: hint the language (ISO-639-1, e.g. "en", "zh"). Leave blank to auto-detect.
OPENAI_STT_LANGUAGE=

# Optional: priming prompt to bias transcription (jargon, names, etc.)
OPENAI_STT_PROMPT=

# Optional: HTTP timeout for OpenAI calls (seconds)
OPENAI_STT_TIMEOUT_SECONDS=120

# ─────────── Log-file voice telemetry (event.log / channel.log) ───────────
# Root directory containing scenario folders (each with event.log and/or channel.log).
# Relative paths are resolved from the repository root.
# Scenario folders live under output/ (run telemetry-generator/generate_all.py first)
TELEMETRY_LOG_ROOT=telemetry/telemetry-generator/output
TELEMETRY_DEFAULT_SCENARIO=test_1_straight_line
# Model used to parse voice commands into query_event_log / query_channel_log intents
OPENAI_INTENT_MODEL=gpt-4o-mini
VOICE_TELEMETRY_ENABLED=true

# ─────────── InfluxDB (telemetry query API: GET /api/query/*) ───────────
# Must match your Influx / ingestor setup (see telemetry/).
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=aistra-dev-token-12345
INFLUX_ORG=aistra-org
INFLUX_BUCKET=telemetry

# Optional: HTTP timeout for Influx (milliseconds). Prevents hung requests if DB is down.
INFLUX_TIMEOUT_MS=30000

# Optional: for GET .../query/channel only — Flux window end is ``at``; window start is
# ``at - INFLUX_POINT_LOOKBACK_SECONDS``. Do not use unbounded ``range(start: 0)`` (it freezes).
INFLUX_POINT_LOOKBACK_SECONDS=2592000
