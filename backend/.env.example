# ASTRA Backend - Environment for integrated demo
# Copy to .env and adjust as needed

# Whisper API URL (transcription service)
# Default: same machine, Whisper runs on port 8001
WHISPER_API_URL=http://127.0.0.1:8001

# Base URL for callback - Whisper will POST here when done
# Use host machine URL if Whisper runs in Docker (e.g. host.docker.internal:8000)
BACKEND_BASE_URL=http://127.0.0.1:8000
