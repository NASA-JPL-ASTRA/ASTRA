# Copy this file to frontend/.env.local and adjust if needed.
# DO NOT commit the real .env.local file.

# Backend REST API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000/api

# Session-scoped WebSocket base URL (frontend will append /{sessionId})
VITE_SESSION_WS_URL=ws://localhost:8000/ws/sessions
